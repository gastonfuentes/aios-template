<?xml version="1.0" encoding="UTF-8"?>
<!--
  AIOS nightly memory consolidation — launchd agent (PRP-027 Fase 4 {{AGENT_NAME}}).

  Carga (operación c1 del operador, una sola vez):
    cp <PROJECT_ROOT>/agent-server/launchd/com.aios.nightly-memory-consolidation.plist \
       ~/Library/LaunchAgents/com.aios.nightly-memory-consolidation.plist
    launchctl bootstrap gui/$UID ~/Library/LaunchAgents/com.aios.nightly-memory-consolidation.plist
    launchctl print gui/$UID/com.aios.nightly-memory-consolidation

  Forzar run manual:
    launchctl kickstart -k gui/$UID/com.aios.nightly-memory-consolidation

  Logs:
    ~/Library/Logs/aios/nightly-memory-consolidation.out.log
    ~/Library/Logs/aios/nightly-memory-consolidation.err.log

  Schedule: cada noche 3:00am Guadalajara (TZ explícita en EnvironmentVariables).
  Vive FUERA del scheduler del daemon (refinamiento canónico durante PRP-027 —
  ver "Refinamientos a la Directiva durante este PRP" en PRP-027).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aios.nightly-memory-consolidation</string>

  <key>ProgramArguments</key>
  <array>
    <string><PROJECT_ROOT>/agent-server/node_modules/.bin/tsx</string>
    <string><PROJECT_ROOT>/agent-server/scripts/consolidate.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string><PROJECT_ROOT>/agent-server</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>EnvironmentVariables</key>
  <dict>
    <key>TZ</key>
    <string>America/Mexico_City</string>
    <key>HOME</key>
    <string><HOME></string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>StandardOutPath</key>
  <string><HOME>/Library/Logs/aios/nightly-memory-consolidation.out.log</string>

  <key>StandardErrorPath</key>
  <string><HOME>/Library/Logs/aios/nightly-memory-consolidation.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
