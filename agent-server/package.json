{
  "name": "aios-template-agent-server",
  "version": "0.1.0",
  "description": "Daemon Node 20+ del template AIOS — Claude Agent SDK + HTTP server + SQLite. Long-lived process del operador (laptop, mini-PC, o VPS).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "index-memories": "tsx scripts/index-memories.ts",
    "consolidate": "tsx scripts/consolidate.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@anthropic-ai/claude-agent-sdk": "0.2.128",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@supabase/supabase-js": "^2.105.4",
    "ai": "^6.0.184",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^4.9.0",
    "date-fns": "^4.1.0",
    "grammy": "^1.30.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
