# =============================================================================
# AIOS Template — agent-server (.env.example)
# =============================================================================
# Copia este archivo a `.env` y completa los valores. `.env` está gitignored.
# Sembrar valores compartidos byte-exact con `mission-control/.env.local` cuando
# el comentario lo indique.
# =============================================================================

# === Supabase ===
# El daemon usa service_role para escribir a `ops_events` bypass-eando RLS.
# Trust boundary: daemon local del operador + bearer; NUNCA expuesto al frontend.
# Obtener:
#   1. Crea project en https://supabase.com/dashboard
#   2. Settings → API → Project URL + service_role JWT (NO el anon)
MC_SUPABASE_URL=https://<your-project-ref>.supabase.co
MC_SUPABASE_KEY=<service_role JWT del project>

# === Daemon HTTP server ===
# Puerto local del daemon. Default 3099. CORS bloquea cualquier origen distinto
# a MISSION_CONTROL_ORIGIN. Bearer canónico `OPENCLAW_GATEWAY_TOKEN` validado
# con crypto.timingSafeEqual (resistente a timing attacks).
MC_SERVER_PORT=3099
OPENCLAW_GATEWAY_TOKEN=<bearer compartido byte-exact con mission-control/.env.local>
# CSV de orígenes permitidos. Sembrar localhost para dev + URL pública del MC en prod
# (ej. "http://localhost:3000,https://mission-control.yourdomain.com").
MISSION_CONTROL_ORIGIN=http://localhost:3000

# === Mission Control bridge (always-push receiver) ===
# El daemon postea fire-and-forget a estos endpoints del MC tras cerrar streams,
# crons, errores. Bearer outgoing = bearer entrante.
MISSION_CONTROL_URL=http://localhost:3000/api/openclaw/event
MISSION_CONTROL_TOKEN=<= OPENCLAW_GATEWAY_TOKEN, mismo valor byte-exact>
# Base URL del MC al que el daemon postea always-push de chat (`/api/chat/complete`).
# Sembrar con la URL pública del MC para que el always-push funcione en prod.
# En dev local puedes omitirla (fallback canónico al primer origin del CSV).
MC_BASE_URL=https://<your-mc-public-url>

# === Telegram bot (opcional, fail-soft sin tokens) ===
# Crea bot vía @BotFather en Telegram + obtén el chat_id de tu cuenta enviando
# /chatid al bot tras configurarlo.
TELEGRAM_BOT_TOKEN=<de @BotFather>
ALLOWED_CHAT_ID=<chat_id único autorizado>

# === Voice STT/TTS (opcional) ===
# STT: Groq Whisper-large-v3. Obtener: https://console.groq.com/keys
# TTS: ElevenLabs Flash v2.5. Obtener: https://elevenlabs.io/app/settings/api-keys
# Si vacíos, el bot Telegram responde voice notes con texto plano.
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# === Cron scheduler ===
# Zona horaria del scheduler. Default America/Mexico_City. Cambia a tu TZ
# (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
SCHEDULER_TZ=America/Mexico_City

# === Google Workspace skill (opcional) ===
# Para usar la skill `google-workspace` (Gmail + Calendar via CLI `gog`).
# GOG_KEYRING_PASSWORD: password del keyring del SO donde `gog` guarda tokens OAuth.
# GOG_ENABLE_COMMANDS: si "1", el daemon puede invocar `gog` desde tools (cuidado).
GOG_KEYRING_PASSWORD=
GOG_ENABLE_COMMANDS=

# === Memoria semántica (opcional, fail-soft sin OPENAI_API_KEY) ===
# Endpoints POST /embed y GET /recall retornan 503 si OPENAI_API_KEY vacío.
# El daemon arranca igual; la skill `recall` degrada al fallback Bash+Read.
# Modelo default: text-embedding-3-small (1536 dim).
OPENAI_API_KEY=<sk-...>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Prefix de tabla + RPCs Supabase para memoria semántica. Default `agent` →
# `agent_memories`, `match_agent_memories`, `touch_agent_memory`, `decay_agent_memories`,
# `compact_agent_memories`. Override si migras desde un schema preexistente con
# otro naming.
MEMORY_TABLE_PREFIX=agent

# Nombre del subagente del template para construir la ruta `.claude/agent-memory/<name>/`.
# Default `agent`. Setear al nombre que elegiste durante INTERVIEW.md (ej. "echo", "nova").
AGENT_NAME=agent

# === Nightly memory consolidation (opcional) ===
# Cron `nightly-memory-consolidation` extrae hechos atómicos del chat del día.
# Todos opcionales con defaults conservadores.
#
# MEMORY_CONSOLIDATION_MODEL — modelo cheap para extracción
#   (default: claude-sonnet-4-5).
# MEMORY_DECAY_FACTOR — multiplicador `importance` para memorias viejas no accedidas
#   (default: 0.95; rango (0, 1]).
# MEMORY_DECAY_AGE_DAYS — umbral antigüedad para decay (default: 30 días).
# MEMORY_DECAY_HITS — umbral accessed_count para decay (default: 3 hits).
# MEMORY_COMPACT_THRESHOLD — `importance` debajo del cual la memoria se borra
#   (default: 0.1).
MEMORY_CONSOLIDATION_MODEL=
MEMORY_DECAY_FACTOR=
MEMORY_DECAY_AGE_DAYS=
MEMORY_DECAY_HITS=
MEMORY_COMPACT_THRESHOLD=

# === PWA push notifications (sembrar byte-exact en mission-control/.env.local) ===
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# === Logging ===
LOG_LEVEL=info
NODE_ENV=development
